---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  benefits,
  contact,
  footerLinks,
  galleryCards,
  heroHighlights,
  introCopy,
  navLinks,
  officeHours,
  services,
  socialLinks,
} from '../data/site';

const base = import.meta.env.BASE_URL;
const asset = (path) => `${base}${path.replace(/^\//, '')}`;

const heroStats = [
  { label: 'Serving', value: heroHighlights[0] },
  { label: 'Address', value: heroHighlights[1] },
  { label: 'Phone', value: heroHighlights[2] },
];

const quickLinks = [
  { label: 'Patient Portal', href: 'https://theschedulingapp.com/HealthyValleyChiropractic' },
  { label: 'Review Us', href: 'https://www.healthyvalleychiropractic.com/review-us/' },
];
---

<BaseLayout
  title="Healthy Valley Chiropractic | State College, PA"
  description="Healthy Valley Chiropractic provides chiropractic care in State College, Pennsylvania."
  image="images/slide2.jpg"
>
  <main id="top">
    <a class="skip-link" href="#content">Skip to content</a>

    <header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/82 backdrop-blur-xl">
      <div class="shell grid items-center gap-4 py-4 lg:grid-cols-[auto_1fr_auto] lg:gap-6">
        <a href="#top" class="flex items-center gap-3 self-start">
          <img
            src={asset('/images/logo@2x.png')}
            alt="Healthy Valley Chiropractic"
            class="h-12 w-12 rounded-2xl border border-slate-200 bg-white object-cover shadow-sm"
          />
          <div class="leading-tight">
            <p class="text-sm font-semibold tracking-tight text-slate-950 sm:text-base">Healthy Valley Chiropractic</p>
            <p class="text-xs uppercase tracking-[0.24em] text-slate-500">State College, PA</p>
          </div>
        </a>

        <nav class="hidden items-center justify-center gap-7 lg:flex" aria-label="Primary navigation">
          {navLinks.map((link) => (
            <a href={link.href} class="text-sm font-medium text-slate-600 hover:text-slate-950">
              {link.label}
            </a>
          ))}
        </nav>

        <div class="flex flex-wrap items-center gap-2 sm:gap-3 lg:justify-self-end">
          <a href={contact.phoneHref} class="text-sm font-semibold text-slate-700 hover:text-slate-950">
            {contact.phone}
          </a>
          <a
            href="https://www.healthyvalleychiropractic.com/special/"
            target="_blank"
            rel="noreferrer"
            class="button button-primary text-xs sm:text-sm"
          >
            SCHEDULE
          </a>
        </div>
      </div>
    </header>

    <section id="content" class="section pt-10 sm:pt-14 lg:pt-16">
      <div class="shell grid gap-10 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:gap-14">
        <div class="space-y-8">
          <div class="space-y-4">
            <p class="kicker">{heroHighlights[0]}</p>
            <h1 class="section-heading max-w-[12ch]">
              Chiropractic care with a polished local feel
            </h1>
            <p class="subcopy max-w-2xl">
              Healthy Valley Chiropractic brings a calm, professional experience to State College — with a focus on
              back pain, neck pain, and muscle strain care.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a
              href="https://www.healthyvalleychiropractic.com/special/"
              target="_blank"
              rel="noreferrer"
              class="button button-primary"
            >
              NEW PATIENT SPECIAL OFFER
            </a>
            <a href="#contact" class="button button-secondary">Contact</a>
            <a href={contact.phoneHref} class="button button-secondary">Call now</a>
          </div>

          <div class="panel-soft max-w-4xl p-4 sm:p-5">
            <div class="grid gap-3 sm:grid-cols-3">
              {heroStats.map((item) => (
                <div class="metric-card">
                  <p class="text-[0.66rem] font-semibold uppercase tracking-[0.3em] text-emerald-700">{item.label}</p>
                  <p class="mt-2 text-sm font-semibold leading-6 tracking-tight text-slate-800">{item.value}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="panel-soft max-w-2xl p-5 sm:p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-emerald-700">Visit essentials</p>
            <div class="mt-4 grid gap-3 sm:grid-cols-3">
              <div class="soft-card bg-white">
                <p class="muted-label">Start here</p>
                <p class="mt-2 text-sm leading-6 text-slate-700">Call the office or use the patient portal to get started.</p>
              </div>
              <div class="soft-card bg-white">
                <p class="muted-label">What to expect</p>
                <p class="mt-2 text-sm leading-6 text-slate-700">Straightforward visits, clear explanations, and a calm setting.</p>
              </div>
              <div class="soft-card bg-white">
                <p class="muted-label">Local convenience</p>
                <p class="mt-2 text-sm leading-6 text-slate-700">Downtown State College access with contact options that are easy to find.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-[0.92fr_1.08fr]">
          <figure class="panel group relative overflow-hidden sm:row-span-2">
            <img
              src={asset('/images/dr-jay-explaining-decompression.jpg')}
              alt="Healthy Valley Chiropractic doctor demonstrating decompression"
              class="h-full min-h-[34rem] w-full object-cover transition duration-700 group-hover:scale-[1.02]"
              fetchpriority="high"
            />
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-slate-950/45 via-slate-950/8 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-4 sm:p-5">
              <div class="panel-soft max-w-md bg-white/92 p-4 shadow-[0_20px_40px_rgba(15,23,42,0.12)]">
                <p class="text-[0.66rem] font-semibold uppercase tracking-[0.3em] text-emerald-700">Healthy Valley Chiropractic</p>
                <p class="mt-2 text-base font-semibold tracking-tight text-slate-950">403 South Allen Street #112A</p>
                <p class="mt-1 text-sm leading-6 text-slate-600">State College, PA 16801 · {contact.phone}</p>
              </div>
            </div>
          </figure>

          <figure class="panel overflow-hidden">
            <img
              src={asset('/images/ig-honor.jpg')}
              alt="Healthy Valley Chiropractic community recognition image"
              class="h-56 w-full object-cover sm:h-64"
              loading="eager"
            />
          </figure>

          <figure class="panel overflow-hidden">
            <img
              src={asset('/images/services-balance-training@2x.jpg')}
              alt="Healthy Valley Chiropractic balance training image"
              class="h-56 w-full object-cover sm:h-64"
              loading="eager"
            />
          </figure>
        </div>
      </div>
    </section>

    <section id="about" class="section section-alt pt-4 sm:pt-8 lg:pt-10">
      <div class="shell grid gap-8 lg:grid-cols-[0.94fr_1.06fr] lg:items-center">
        <figure class="panel overflow-hidden">
          <img
            src={asset('/images/dr-craig-baniszewski.jpg')}
            alt="Healthy Valley Chiropractic doctor portrait"
            class="h-full min-h-[420px] w-full object-cover"
            loading="eager"
          />
        </figure>

        <div>
          <span class="eyebrow">HEALTHY VALLEY CHIROPRACTIC</span>
          <h2 class="heading section-heading mt-5">Is chiropractic right for you?</h2>
          <p class="mt-4 text-sm font-medium uppercase tracking-[0.28em] text-slate-500">A closer look at care</p>

          <div class="mt-6 flex flex-wrap gap-2">
            {benefits.map((item) => (
              <span class="label-chip">{item}</span>
            ))}
          </div>

          <div class="mt-8 space-y-5">
            {introCopy.map((paragraph) => (
              <p class="section-copy">{paragraph}</p>
            ))}
          </div>

          <div class="mt-8 grid gap-3 sm:grid-cols-2">
            <div class="soft-card bg-white">
              <p class="muted-label">Office</p>
              <p class="mt-1 text-base font-semibold text-slate-950">State College, Pennsylvania</p>
            </div>
            <div class="soft-card bg-white">
              <p class="muted-label">Phone</p>
              <a class="mt-1 block text-base font-semibold text-slate-950" href={contact.phoneHref}>{contact.phone}</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="services" class="section">
      <div class="shell">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <span class="eyebrow">CHIROPRACTIC CARE CAN HELP</span>
            <h2 class="heading section-heading mt-5">Services highlighted on the practice site</h2>
          </div>
          <a class="button button-secondary w-fit" href="https://www.healthyvalleychiropractic.com/contact-us/" target="_blank" rel="noreferrer">
            Contact
          </a>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
          {services.map((service, index) => (
            <a href={service.href} class="card group flex h-full flex-col" target="_blank" rel="noreferrer">
              <div class="card-media relative aspect-[4/3]">
                <img src={asset(service.image)} alt={service.title} loading="eager" />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/35 via-transparent to-transparent"></div>
                <div class="absolute inset-x-0 bottom-0 p-5">
                  <p class="text-xs font-semibold uppercase tracking-[0.28em] text-white/80">0{index + 1}</p>
                </div>
              </div>
              <div class="flex flex-1 flex-col space-y-3 p-5">
                <h3 class="text-xl font-semibold tracking-tight text-slate-950 group-hover:text-emerald-700">{service.title}</h3>
                <p class="text-sm leading-7 text-slate-600">{service.description}</p>
                <div class="mt-auto pt-4 text-sm font-semibold text-emerald-700">View details</div>
              </div>
            </a>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          {quickLinks.map((link) => (
            <a class="button button-secondary" href={link.href} target="_blank" rel="noreferrer">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-alt">
      <div class="shell">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <span class="eyebrow">INSIDE THE PRACTICE</span>
            <h2 class="heading section-heading mt-5">Real photography from the office and community</h2>
          </div>
          <p class="text-sm text-slate-500">A clean, real-world look instead of generic stock placeholders.</p>
        </div>

        <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
          {galleryCards.map((card) => (
            <figure class="card group overflow-hidden">
              <div class="card-media relative aspect-[4/3]">
                <img src={asset(card.image)} alt={card.title} loading="eager" />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/55 via-slate-950/8 to-transparent"></div>
                <div class="absolute inset-x-0 bottom-0 p-5 text-white">
                  <p class="text-xs font-semibold uppercase tracking-[0.28em] text-white/70">Healthy Valley Chiropractic</p>
                  <h3 class="mt-2 text-lg font-semibold tracking-tight">{card.title}</h3>
                  <p class="mt-1 text-sm text-white/80">{card.caption}</p>
                </div>
              </div>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section id="hours" class="section">
      <div class="shell grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-start">
        <div class="panel bg-white p-6 sm:p-8">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <span class="eyebrow">OFFICE HOURS</span>
              <h2 class="heading mt-5 text-3xl sm:text-4xl">Plan your visit</h2>
            </div>
            <p class="text-sm text-slate-500">State College, PA</p>
          </div>

          <div class="mt-8 overflow-hidden rounded-[1.5rem] border border-slate-200">
            {officeHours.map((row) => (
              <div class="grid gap-3 border-b border-slate-200 bg-white px-5 py-4 last:border-b-0 sm:grid-cols-[160px_1fr] sm:items-start">
                <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">{row.day}</p>
                <div class="space-y-1 text-sm text-slate-700">
                  {row.hours.map((hour) => (
                    <p>{hour}</p>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="grid gap-6">
          <div class="panel overflow-hidden bg-white">
            <div class="relative">
              <img
                src={asset('/images/practice-sign.jpg')}
                alt="Healthy Valley Chiropractic practice sign"
                class="h-64 w-full object-cover sm:h-72"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950/82 via-slate-950/24 to-transparent"></div>
              <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8">
                <span class="eyebrow border-white/15 bg-white/10 text-white/90">CONTACT</span>
                <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Visit Healthy Valley Chiropractic</h2>
              </div>
            </div>

            <div class="space-y-4 p-6 sm:p-8">
              <div class="grid gap-4 text-sm sm:grid-cols-2">
                <div class="soft-card bg-slate-50">
                  <p class="muted-label">Phone</p>
                  <a class="mt-1 block text-base font-semibold text-slate-950" href={contact.phoneHref}>{contact.phone}</a>
                </div>
                <div class="soft-card bg-slate-50">
                  <p class="muted-label">Address</p>
                  <p class="mt-1 text-base font-semibold text-slate-950">{contact.address}</p>
                </div>
              </div>

              <div class="flex flex-wrap gap-3">
                <a class="button button-primary" href="https://www.healthyvalleychiropractic.com/contact-us/" target="_blank" rel="noreferrer">
                  Contact page
                </a>
                <a class="button button-secondary" href="https://www.healthyvalleychiropractic.com/special/" target="_blank" rel="noreferrer">
                  New patient special offer
                </a>
              </div>
            </div>
          </div>

          <div class="panel overflow-hidden bg-white">
            <img
              src={asset('/images/dr-jay-explaining-decompression.jpg')}
              alt="Healthy Valley Chiropractic doctor demonstrating decompression"
              class="h-64 w-full object-cover sm:h-72"
              loading="eager"
            />
            <div class="space-y-4 p-6 sm:p-8">
              <span class="eyebrow">Map</span>
              <p class="text-xl font-semibold tracking-tight text-slate-950">Google Maps</p>
              <div class="soft-card overflow-hidden p-0">
                <iframe
                  title="Healthy Valley Chiropractic location"
                  src={contact.mapSrc}
                  loading="eager"
                  referrerpolicy="no-referrer-when-downgrade"
                  class="h-72 w-full border-0"
                ></iframe>
              </div>
              <div class="soft-card bg-slate-50 text-sm leading-7 text-slate-700">
                <p class="font-semibold text-slate-950">Healthy Valley Chiropractic</p>
                <p>{contact.address}</p>
              </div>
              <div class="flex flex-wrap gap-3">
                <a class="button button-primary" href="https://g.page/healthy-valley-chiropractic?share" target="_blank" rel="noreferrer">
                  Google Maps
                </a>
                <a class="button button-secondary" href="https://www.healthyvalleychiropractic.com/contact-us/" target="_blank" rel="noreferrer">
                  Contact page
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-slate-200 bg-white/85 py-10 backdrop-blur-sm">
    <div class="shell space-y-8 text-sm text-slate-500">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
        <div class="space-y-4">
          <div>
            <p class="font-semibold text-slate-900">Healthy Valley Chiropractic</p>
            <p>State College, Pennsylvania</p>
          </div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Copyright © 2026</p>
          <div class="flex flex-wrap gap-2">
            {socialLinks.map((link) => (
              <a
                class="soft-card bg-slate-50 px-3 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-slate-600 hover:border-slate-300 hover:text-slate-950"
                href={link.href}
                target="_blank"
                rel="noreferrer"
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>

        <a class="button button-primary w-fit" href="https://www.healthyvalleychiropractic.com/special/" target="_blank" rel="noreferrer">
          NEW PATIENT SPECIAL OFFER
        </a>
      </div>

      <div class="grid gap-4 border-t border-slate-200 pt-5 sm:grid-cols-2 lg:grid-cols-4">
        {footerLinks.map((link) => (
          <a class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-600 hover:border-slate-300 hover:text-slate-950" href={link.href} target="_blank" rel="noreferrer">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </footer>
</BaseLayout>

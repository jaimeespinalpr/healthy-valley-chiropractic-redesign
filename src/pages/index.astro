---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  aboutLinks,
  benefits,
  contact,
  footerLinks,
  heroHighlights,
  introCopy,
  navLinks,
  officeHours,
  quote,
  services,
  socialLinks,
  supportPoints,
} from '../data/site';

const base = import.meta.env.BASE_URL;
const asset = (path) => `${base}${path.replace(/^\//, '')}`;

const heroStats = [
  { label: 'Serving', value: heroHighlights[0] },
  { label: 'Address', value: heroHighlights[1] },
  { label: 'Phone', value: heroHighlights[2] },
];
---

<BaseLayout
  title="New Patient Special | Chiropractor State College PA"
  description="Healthy Valley Chiropractic located in State College."
>
  <main id="top">
    <a class="skip-link" href="#content">Skip to content</a>

    <header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/85 backdrop-blur-xl">
      <div class="shell flex flex-col gap-4 py-4 lg:flex-row lg:items-center lg:justify-between">
        <a href="#top" class="flex items-center gap-3 self-start">
          <img
            src={asset('/images/logo@2x.png')}
            alt="Healthy Valley Chiropractic"
            class="h-12 w-12 rounded-2xl border border-slate-200 bg-white object-cover shadow-sm"
          />
          <div class="leading-tight">
            <p class="text-sm font-semibold tracking-tight text-slate-950 sm:text-base">Healthy Valley Chiropractic</p>
            <p class="text-xs uppercase tracking-[0.24em] text-slate-500">State College, PA</p>
          </div>
        </a>

        <nav class="hidden items-center gap-7 xl:flex" aria-label="Primary navigation">
          {navLinks.map((link) => (
            <a href={link.href} class="text-sm font-medium text-slate-600 hover:text-slate-950">
              {link.label}
            </a>
          ))}
        </nav>

        <div class="flex flex-wrap items-center gap-2 sm:gap-3">
          <a href={contact.phoneHref} class="text-sm font-semibold text-slate-700 hover:text-slate-950">
            {contact.phone}
          </a>
          <a
            href="https://www.healthyvalleychiropractic.com/special/"
            target="_blank"
            rel="noreferrer"
            class="button button-primary text-xs sm:text-sm"
          >
            SCHEDULE
          </a>
        </div>
      </div>
    </header>

    <section id="content" class="section pt-10 sm:pt-14 lg:pt-16">
      <div class="shell grid gap-10 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:gap-14">
        <div class="space-y-8">
          <p class="kicker">Serving The State College Area</p>

          <div class="max-w-3xl space-y-6">
            <h1 class="heading max-w-[11ch] text-4xl leading-[0.92] sm:text-5xl lg:text-6xl xl:text-[4.65rem]">
              Taking Chiropractic
              <span class="block text-emerald-700">Care to the Next Level</span>
            </h1>
            <p class="subcopy">Healthy Valley Chiropractic located in State College.</p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a
              href="https://www.healthyvalleychiropractic.com/special/"
              target="_blank"
              rel="noreferrer"
              class="button button-primary"
            >
              NEW PATIENT SPECIAL OFFER
            </a>
            <a href="#contact" class="button button-secondary">Contact</a>
          </div>

          <div class="panel-soft max-w-3xl p-4 sm:p-5">
            <div class="grid gap-3 sm:grid-cols-3">
              {heroStats.map((item) => (
                <div class="rounded-[1.3rem] border border-slate-200/80 bg-white px-4 py-4 shadow-sm">
                  <p class="text-[0.66rem] font-semibold uppercase tracking-[0.3em] text-emerald-700">{item.label}</p>
                  <p class="mt-2 text-sm font-semibold leading-6 tracking-tight text-slate-800">{item.value}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="panel-soft max-w-2xl p-5 sm:p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-emerald-700">No Risk</p>
            <p class="mt-3 text-lg leading-8 text-slate-800 sm:text-xl">
              There is <span class="font-semibold text-slate-950">No Risk</span> to see what we can do for you.
            </p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-[1.15fr_0.85fr]">
          <figure class="panel group relative overflow-hidden sm:row-span-2">
            <img
              src={asset('/images/slide1.jpg')}
              alt="Healthy Valley Chiropractic featured interior"
              class="h-full min-h-[31rem] w-full object-cover transition duration-700 group-hover:scale-[1.02]"
              fetchpriority="high"
            />
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-slate-950/25 via-slate-950/5 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-4 sm:p-5">
              <div class="panel-soft max-w-md bg-white/90 p-4 shadow-[0_20px_40px_rgba(15,23,42,0.12)]">
                <p class="text-[0.66rem] font-semibold uppercase tracking-[0.3em] text-emerald-700">Serving The State College Area</p>
                <p class="mt-2 text-base font-semibold tracking-tight text-slate-950">Healthy Valley Chiropractic</p>
                <p class="mt-1 text-sm leading-6 text-slate-600">403 South Allen Street #112A · (814) 810-3395</p>
              </div>
            </div>
          </figure>

          <figure class="panel overflow-hidden">
            <img
              src={asset('/images/staff-wide.jpg')}
              alt="Healthy Valley Chiropractic staff wide image"
              class="h-60 w-full object-cover"
              loading="lazy"
            />
          </figure>

          <figure class="panel overflow-hidden">
            <img
              src={asset('/images/front-desk-wide.jpg')}
              alt="Chiropractic State Valley PA Healthy Valley Chiropractic scroll"
              class="h-60 w-full object-cover"
              loading="lazy"
            />
          </figure>
        </div>
      </div>
    </section>

    <section id="about" class="section pt-4 sm:pt-8 lg:pt-10">
      <div class="shell grid gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
        <figure class="panel overflow-hidden">
          <img
            src={asset('/images/dr-jay-explaining-decompression.jpg')}
            alt="Healthy Valley Chiropractic doctor explaining decompression"
            class="h-full min-h-[420px] w-full object-cover"
            loading="lazy"
          />
        </figure>

        <div>
          <span class="eyebrow">HEALTHY VALLEY CHIROPRACTIC</span>
          <h2 class="heading mt-5 max-w-2xl text-3xl sm:text-4xl lg:text-5xl">Is chiropractic right for you?</h2>
          <p class="mt-4 text-sm font-medium uppercase tracking-[0.28em] text-slate-500">Is chiropractic right for you?</p>

          <div class="mt-6 flex flex-wrap gap-2">
            {benefits.map((item) => (
              <span class="rounded-full border border-emerald-700/10 bg-white px-4 py-2 text-xs font-semibold tracking-[0.24em] text-slate-600 shadow-sm">
                {item}
              </span>
            ))}
          </div>

          <div class="mt-8 space-y-5">
            {introCopy.map((paragraph) => (
              <p class="max-w-2xl text-base leading-8 text-slate-600 sm:text-lg">{paragraph}</p>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="services" class="section">
      <div class="shell">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <span class="eyebrow">CHIROPRACTIC CARE CAN HELP</span>
            <h2 class="heading mt-5 max-w-2xl text-3xl sm:text-4xl lg:text-5xl">
              Contact us today to see how we can help you feel better today.
            </h2>
          </div>
          <a class="button button-secondary w-fit" href="https://www.healthyvalleychiropractic.com/contact-us/" target="_blank" rel="noreferrer">
            Contact
          </a>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-3">
          {services.map((service, index) => (
            <a href={service.href} class="card group block h-full" target="_blank" rel="noreferrer">
              <div class="card-media relative aspect-[4/3]">
                <img src={asset(service.image)} alt={service.title} loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/35 via-transparent to-transparent"></div>
                <div class="absolute inset-x-0 bottom-0 p-5">
                  <p class="text-xs font-semibold uppercase tracking-[0.28em] text-white/80">0{index + 1}</p>
                </div>
              </div>
              <div class="space-y-3 p-5">
                <h3 class="text-xl font-semibold tracking-tight text-slate-950 group-hover:text-emerald-700">{service.title}</h3>
                <p class="text-sm leading-7 text-slate-600">{service.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="hours" class="section">
      <div class="shell grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-start">
        <div class="panel bg-white p-6 sm:p-8">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <span class="eyebrow">OFFICE HOURS</span>
              <h2 class="heading mt-5 text-3xl sm:text-4xl">Office hours</h2>
            </div>
            <p class="text-sm text-slate-500">State College, PA</p>
          </div>

          <div class="mt-8 divide-y divide-slate-200 overflow-hidden rounded-[1.5rem] border border-slate-200">
            {officeHours.map((row) => (
              <div class="grid gap-3 bg-white px-5 py-4 sm:grid-cols-[160px_1fr] sm:items-start">
                <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">{row.day}</p>
                <div class="space-y-1 text-sm text-slate-700">
                  {row.hours.map((hour) => (
                    <p>{hour}</p>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="grid gap-6">
          <div class="panel bg-white p-6 sm:p-8">
            <p class="kicker">GET YOUR LIFESTYLE BACK</p>
            <p class="mt-4 text-2xl leading-10 text-slate-800 sm:text-3xl">
              You don't have to live in pain. We are here to help you get your life back.
            </p>
            <a href="https://www.healthyvalleychiropractic.com/special/" target="_blank" rel="noreferrer" class="button button-primary mt-6">
              NEW PATIENT SPECIAL OFFER
            </a>
          </div>

          <blockquote class="panel border-emerald-700/10 bg-emerald-50/80 p-6 sm:p-8">
            <p class="kicker">{quote.author}</p>
            <p class="mt-4 text-2xl leading-10 text-slate-800 sm:text-3xl">“{quote.text}”</p>
          </blockquote>

          <div class="panel bg-white p-6 sm:p-8">
            <div class="grid gap-3 text-sm text-slate-700 sm:grid-cols-2">
              {supportPoints.map((item) => (
                <div class="soft-card bg-slate-50">{item}</div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section pt-0">
      <div class="shell">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <span class="eyebrow">ABOUT</span>
            <h2 class="heading mt-5 text-3xl sm:text-4xl">Explore more from the practice</h2>
          </div>
          <p class="text-sm text-slate-500">Healthy Valley Chiropractic</p>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {aboutLinks.map((link) => (
            <a class="group link-card" href={link.href} target="_blank" rel="noreferrer">
              <span class="text-base font-semibold tracking-tight text-slate-950">{link.label}</span>
              <span class="text-slate-400 transition group-hover:translate-x-0.5 group-hover:text-emerald-700">↗</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="section pt-0">
      <div class="shell grid gap-6 xl:grid-cols-[1.02fr_0.98fr] xl:items-start">
        <div class="panel overflow-hidden bg-white">
          <div class="relative">
            <img
              src={asset('/images/contact-us-bg.jpg')}
              alt="Healthy Valley Chiropractic office contact image"
              class="h-72 w-full object-cover sm:h-80"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950/82 via-slate-950/24 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8">
              <span class="eyebrow border-white/15 bg-white/10 text-white/90">CONTACT</span>
              <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Healthy Valley Chiropractic</h2>
            </div>
          </div>

          <div class="space-y-4 p-6 sm:p-8">
            <div class="grid gap-4 text-sm sm:grid-cols-2">
              <div class="soft-card bg-slate-50">
                <p class="muted-label">Phone</p>
                <a class="mt-1 block text-base font-semibold text-slate-950" href={contact.phoneHref}>{contact.phone}</a>
              </div>
              <div class="soft-card bg-slate-50">
                <p class="muted-label">Address</p>
                <p class="mt-1 text-base font-semibold text-slate-950">{contact.address}</p>
              </div>
            </div>

            <div class="flex flex-wrap gap-3">
              <a class="button button-primary" href="https://www.healthyvalleychiropractic.com/contact-us/" target="_blank" rel="noreferrer">
                Contact page
              </a>
              <a class="button button-secondary" href="https://www.healthyvalleychiropractic.com/special/" target="_blank" rel="noreferrer">
                New patient special offer
              </a>
            </div>
          </div>
        </div>

        <div class="panel overflow-hidden bg-white">
          <img
            src={asset('/images/dr-craig-baniszewski.jpg')}
            alt="Healthy Valley Chiropractic doctor portrait"
            class="h-64 w-full object-cover object-center sm:h-72"
            loading="lazy"
          />
          <div class="space-y-4 p-6 sm:p-8">
            <span class="eyebrow">Map</span>
            <p class="text-xl font-semibold tracking-tight text-slate-950">Google Maps</p>
            <div class="soft-card overflow-hidden p-0">
              <iframe
                title="Healthy Valley Chiropractic location"
                src={contact.mapSrc}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                class="h-72 w-full border-0"
              ></iframe>
            </div>
            <div class="soft-card bg-slate-50 text-sm leading-7 text-slate-700">
              <p class="font-semibold text-slate-950">Healthy Valley Chiropractic</p>
              <p>{contact.address}</p>
            </div>
            <div class="flex flex-wrap gap-3">
              <a class="button button-primary" href="https://g.page/healthy-valley-chiropractic?share" target="_blank" rel="noreferrer">
                Google Maps
              </a>
              <a class="button button-secondary" href="https://www.healthyvalleychiropractic.com/contact-us/" target="_blank" rel="noreferrer">
                Contact page
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-slate-200 bg-white/85 py-10 backdrop-blur-sm">
    <div class="shell space-y-8 text-sm text-slate-500">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
        <div class="space-y-3">
          <div>
            <p class="font-semibold text-slate-900">Healthy Valley Chiropractic</p>
            <p>State College, Pennsylvania</p>
          </div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Copyright © 2026</p>
          <div class="flex flex-wrap gap-2">
            {socialLinks.map((link) => (
              <a
                class="soft-card bg-slate-50 px-3 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-slate-600 hover:border-slate-300 hover:text-slate-950"
                href={link.href}
                target="_blank"
                rel="noreferrer"
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>

        <a class="button button-primary w-fit" href="https://www.healthyvalleychiropractic.com/special/" target="_blank" rel="noreferrer">
          NEW PATIENT SPECIAL OFFER
        </a>
      </div>

      <div class="grid gap-3 border-t border-slate-200 pt-5 sm:grid-cols-2 lg:grid-cols-4">
        {footerLinks.map((link) => (
          <a class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-600 hover:border-slate-300 hover:text-slate-950" href={link.href} target="_blank" rel="noreferrer">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </footer>
</BaseLayout>

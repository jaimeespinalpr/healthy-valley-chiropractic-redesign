---
import '../styles/global.css';

const base = import.meta.env.BASE_URL;

const {
  title = 'Healthy Valley Chiropractic | State College, PA',
  description = 'Healthy Valley Chiropractic provides chiropractic care in State College, Pennsylvania.',
  image = 'images/slide2.jpg',
} = Astro.props;

const imageUrl = `${base}${image.replace(/^\//, '')}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8faf8" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${base}images/favicon-square.jpg`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

---
import '../styles/global.css';

const base = import.meta.env.BASE_URL;

const {
  title = 'New Patient Special | Chiropractor State College PA',
  description = 'Healthy Valley Chiropractic in State College, Pennsylvania.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8faf8" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${base}images/favicon-square.jpg`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
